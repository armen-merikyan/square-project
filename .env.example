# OpenAI settings
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Stripe payment links
# Static sites only publish buy.stripe.com payment-link URLs in browser JavaScript.
STRIPE_PRINT_PAYMENT_LINK=https://buy.stripe.com/your-8x8-print-payment-link
STRIPE_FRAMED_PAYMENT_LINK=https://buy.stripe.com/your-8x8-framed-print-payment-link

# Optional: only needed if you want scripts/setup_stripe_shop.py to create Stripe objects.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here
STRIPE_ART_PRODUCT_ID=prod_your-square-project-product-id
STRIPE_PRINT_PRICE_ID=price_your-8x8-print-price-id
STRIPE_FRAMED_PRICE_ID=price_your-8x8-framed-print-price-id

# Backend application settings
DJANGO_SECRET_KEY=replace-with-a-local-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_TIME_ZONE=America/Los_Angeles

# Google OAuth settings
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/google/callback

# Vonage inbound SMS webhook settings
VONAGE_ACCOUNT_SECRET=your-vonage-account-secret
VONAGE_SMS_SIGNATURE_SECRET=your-vonage-signature-secret
VONAGE_SMS_SIGNATURE_ALGORITHM=sha256

# GitHub settings
GITHUB_TOKEN=ghp_your-github-token-here

# Local backend database settings
MYSQL_DATABASE=app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Container build and image tags
AWS_REGION=us-west-2
ACCOUNT_ID=123456789012
BACKEND_IMAGE_REPOSITORY=backend
BACKEND_IMAGE_TAG=latest

# Kumquat platform addon deployment settings
KUMQUAT_KUBECONFIG_PATH=/path/to/kubeconfig
KUMQUAT_HOSTNAME=localhost
KUMQUAT_NAMESPACE=default
KUMQUAT_MYSQL_OPERATOR_NAMESPACE=mysql-operator
KUMQUAT_MYSQL_DATABASE_NAME=app_db
KUMQUAT_MYSQL_APP_USER=app_user
KUMQUAT_MYSQL_ROOT_PASSWORD=root_password
KUMQUAT_MYSQL_APP_PASSWORD=app_password
KUMQUAT_MYSQL_STORAGE_SIZE=10Gi
KUMQUAT_MYSQL_STORAGE_CLASS_NAME=standard
