  "compositional_arguments": [
    {
      "name": "order_vs_chaos",
      "idea": "One side follows a clean pattern while the other breaks apart.",
      "good_for": ["calm_vs_panic", "control_vs_fear", "trust_vs_suspicion", "clarity_vs_confusion", "certainty_vs_doubt"]
    },
    {
      "name": "light_vs_weight",
      "idea": "A small bright shape fights against a heavy dark mass.",
      "good_for": ["hope_vs_grief", "relief_vs_dread", "wonder_vs_melancholy", "renewal_vs_mourning"]
    },
    {
      "name": "center_vs_edges",
      "idea": "The center is protected or attacked by the surrounding pixels.",
      "good_for": ["loneliness", "fear", "defiance", "vulnerability", "reverence"]
    },
    {
      "name": "symmetry_vs_break",
      "idea": "A nearly mirrored image has one wrong or corrupted side.",
      "good_for": ["betrayal", "confusion", "shame_vs_pride", "trust_vs_suspicion", "memory_vs_erasure"]
    },
    {
      "name": "rise_vs_fall",
      "idea": "Pixels move upward on one side and downward on the other.",
      "good_for": ["hope_vs_grief", "pride_vs_shame", "renewal_vs_mourning", "progress_vs_nostalgia"]
    },
    {
      "name": "inside_vs_outside",
      "idea": "A small inner shape is surrounded by pressure, noise, or protection.",
      "good_for": ["fear", "love", "loneliness", "trust", "intimacy_vs_distance"]
    },
    {
      "name": "signal_vs_noise",
      "idea": "One readable pulse tries to survive inside static, interference, and false echoes.",
      "good_for": ["connection_vs_alienation", "clarity_vs_confusion", "signal_vs_noise", "trust_vs_suspicion"]
    },
    {
      "name": "repair_vs_damage",
      "idea": "Broken bands are visibly patched by warmer or steadier pixels.",
      "good_for": ["guilt_vs_forgiveness", "resilience_vs_fragility", "renewal_vs_mourning"]
    },
    {
      "name": "hunger_vs_restraint",
      "idea": "A saturated pull reaches toward a locked border that refuses expansion.",
      "good_for": ["hunger_vs_restraint", "desire_vs_restraint", "emptiness_vs_desire"]
    },
    {
      "name": "near_vs_far",
      "idea": "Close paired marks are separated from distant echoes by a wide quiet field.",
      "good_for": ["intimacy_vs_distance", "longing_vs_resolve", "loneliness_vs_connection"]
    },
    {
      "name": "pressure_vs_release",
      "idea": "Dense pixels collect at one edge and loosen into air across the square.",
      "good_for": ["quiet_vs_pressure", "serenity_vs_urgency", "relief_vs_dread", "panic_vs_control"]
    },
    {
      "name": "memory_vs_motion",
      "idea": "Faded repeated marks are interrupted by a cleaner advancing path.",
      "good_for": ["nostalgia_vs_progress", "memory_vs_erasure", "melancholy_vs_wonder"]
    },
    {
      "name": "exposure_vs_shelter",
      "idea": "A pale exposed center is either protected by a frame or left open to incoming marks.",
      "good_for": ["vulnerability_vs_strength", "safety_vs_exposure", "fear_vs_hope"]
    },
    {
      "name": "overflow_vs_containment",
      "idea": "Bright or hot marks exceed a boundary while cooler marks try to contain them.",
      "good_for": ["euphoria_vs_weariness", "rage_vs_calm", "desire_vs_restraint"]
    }
  ],
